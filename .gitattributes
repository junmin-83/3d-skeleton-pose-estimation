# Normalize all text files to LF in the repository and on checkout (force LF).
* text=auto eol=lf

# Explicit text file types (kept LF on every platform)
*.py    text eol=lf
*.pyi   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf

# Binary files — never touch line endings
*.onnx  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.bmp   binary
*.mp4   binary
*.npy   binary
*.npz   binary
*.pkl   binary
*.mat   binary
*.tar   binary
*.gz    binary
*.tgz   binary
*.bz2   binary
*.zip   binary
